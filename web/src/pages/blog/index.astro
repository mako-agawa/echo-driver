---
import Layout from '../../layouts/Layout.astro'

const res = await fetch('https://echo-driver.mako-agawa.workers.dev/api/posts')
const posts = await res.json()
---

<Layout title="Blog | Echo Driver">
  <nav class="fixed top-0 w-full z-50 glass-nav shadow-[0_40px_40px_rgba(4,7,10,0.06)]">
    <div class="flex justify-between items-center px-8 py-6 max-w-screen-2xl mx-auto">
      <a class="text-2xl font-black tracking-tighter text-[#dce3ea] hover:text-[#c2dc99] transition-colors font-headline" href="/">
        Echo Driver
      </a>
      <div class="hidden md:flex gap-10 items-center">
        <a class="font-headline tracking-tighter uppercase font-bold text-sm text-[#dce3ea]/60 hover:text-[#dce3ea] transition-all" href="#">Projects</a>
        <a class="font-headline tracking-tighter uppercase font-bold text-sm text-[#dce3ea]/60 hover:text-[#dce3ea] transition-all" href="#">Plugins</a>
        <a class="font-headline tracking-tighter uppercase font-bold text-sm text-[#dce3ea]/60 hover:text-[#dce3ea] transition-all" href="#">Music</a>
        <a class="font-headline tracking-tighter uppercase font-bold text-sm text-[#dce3ea]/60 hover:text-[#dce3ea] transition-all" href="/blog">Blog</a>
        <a class="font-headline tracking-tighter uppercase font-bold text-sm text-[#dce3ea]/60 hover:text-[#dce3ea] transition-all" href="#">About</a>
      </div>
      <button class="material-symbols-outlined text-primary">menu</button>
    </div>
  </nav>

  <main class="pt-52 pb-32 max-w-screen-xl mx-auto px-8">
    <div class="mb-20">
      <span class="font-label text-primary uppercase tracking-[0.3em] text-xs mb-4 block">Writing</span>
      <h1 class="font-headline text-5xl md:text-7xl font-black tracking-tighter">BLOG</h1>
    </div>

    <div class="grid gap-1">
      {posts.map((post: any, i: number) => (
        <a
          href={`/blog/${post.slug}`}
          class="group flex flex-col md:flex-row md:items-center justify-between py-8 border-t border-outline-variant/20 hover:bg-surface-container-low/50 px-4 -mx-4 transition-colors"
        >
          <div class="flex items-start gap-8">
            <span class="font-label text-outline text-xs tracking-widest pt-1 w-8">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h2 class="font-headline text-2xl md:text-3xl font-bold tracking-tighter text-on-surface group-hover:text-primary transition-colors mb-2">
                {post.title}
              </h2>
              <div class="flex gap-3 flex-wrap">
                {post.tags.map((tag: string) => (
                  <span class="font-label text-[10px] tracking-widest uppercase text-tertiary border border-tertiary/20 px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
          <div class="flex items-center gap-6 mt-4 md:mt-0 ml-16 md:ml-0">
            <span class="font-label text-outline text-xs tracking-widest">{post.date}</span>
            <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors">arrow_forward</span>
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="font-body text-on-surface-variant">記事はまだありません。</p>
    )}
  </main>
</Layout>
